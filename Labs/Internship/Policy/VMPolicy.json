{
  "properties": {
    "displayName": "Allow Only East US and Standard_D2s_v3 VM Size",
    "policyType": "Custom",
    "mode": "All",
    "description": "This policy allows resources only in East US and West US region and only Standard_D2s_v3 VM size.",
    "metadata": {
      "category": "Compute"
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "field": "location",
            "notIn": [
              "eastus",
              "westus"                                   
            ]
          },
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Compute/virtualMachines"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/sku.name",
                "notEquals": "Standard_D2s_v3"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}

